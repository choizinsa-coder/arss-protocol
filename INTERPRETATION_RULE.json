    }
  ],
  "description": "AIBA Single Source of Interpretation — 동일 SSOT 수신 시 에이전트 해석 분기 방지",
  "domains": {
    "concurrency_control": {
      "description": "동시 세션 이동 허용 여부 해석",
      "priority": 1,
      "rules": [
        {
          "condition": "INTERPRETATION_RULE.json 미완성",
          "external_ref": {
            "id": "DIS-008",
            "schema_version": "2.6"
          },
          "interpretation": "CONCURRENT_BLOCKED",
          "output_label": "STOP — INTERPRETATION_RULE.json 완성 전 동시 세션 이동 불가",
          "priority": 1
        },
        {
          "condition": "canonical_rules.concurrent_session_rule contains '금지'",
          "external_ref": {
            "id": "DIS-008",
            "schema_version": "2.6"
          },
          "interpretation": "CONCURRENT_BLOCKED",
          "output_label": "동시 세션 이동 금지 — DIS-008 적용 중",
          "priority": 2
        },
        {
          "condition": "INTERPRETATION_RULE.json 완성 AND SESSION_CONTEXT LOCKED",
          "external_ref": {
            "id": "DIS-008",
            "schema_version": "2.6"
          },
          "interpretation": "CONCURRENT_ALLOWED",
          "output_label": "동시 세션 이동 허용 가능 — 비오님 최종 확인 필요",
          "priority": 3
        }
      ]
    },
    "execution_gate": {
      "description": "EAG 게이트 상태 해석",
      "priority": 1,
      "rules": [
        {
          "condition": "pending_tasks[0].status == 'EAG_PENDING'",
          "external_ref": {
            "id": "DIS-010",
            "schema_version": "2.6"
          },
          "interpretation": "GATE_OPEN_PENDING_EAG",
          "output_label": "EAG 승인 대기 중 — 비오님 승인 전 실행 불가",
          "priority": 1
        },
        {
          "condition": "pending_tasks[0].status == 'IN_PROGRESS'",
          "external_ref": {
            "id": "DIS-010",
            "schema_version": "2.6"
          },
          "interpretation": "GATE_OPEN_EXECUTING",
          "output_label": "실행 진행 중",
          "priority": 2
        },
        {
          "condition": "pending_tasks[0].status == 'COMPLETED'",
          "external_ref": {
            "id": "DIS-010",
            "schema_version": "2.6"
          },
          "interpretation": "GATE_CLOSED",
          "output_label": "태스크 완료 — 다음 태스크 확인 필요",
          "priority": 3
        },
        {
          "condition": "pending_tasks is empty or null",
          "external_ref": {
            "id": "DIS-008",
            "schema_version": "2.6"
          },
          "interpretation": "GATE_OPEN_NO_BLOCK",
          "output_label": "OPEN — IR-NULL-001 적용",
          "patch_ref": "IR-NULL-001",
          "priority": 4
        }
      ]
    },
    "phase_status": {
      "description": "현재 시스템 phase 해석",
      "priority": 1,
      "rules": [
        {
          "condition": "chain.phase == 'PHASE 1 COMPLETE'",
          "external_ref": {
            "id": "DIS-010",
            "schema_version": "2.6"
          },
          "interpretation": "PHASE_1_COMPLETE",
          "output_label": "Phase 1 완료 — Phase 2 진입 가능 상태",
          "priority": 1
        },
        {
          "condition": "chain.phase == 'PHASE 2 ACTIVE'",
          "external_ref": {
            "id": "DIS-010",
            "schema_version": "2.6"
          },
          "interpretation": "PHASE_2_ACTIVE",
          "output_label": "Phase 2 진행 중",
          "priority": 2
        },
        {
          "condition": "chain.phase == null || chain.phase == ''",
          "external_ref": {
            "id": "DIS-010",
            "schema_version": "2.6"
          },
          "interpretation": "UNKNOWN",
          "output_label": "STOP — phase 미정의. 비오님 확인 필요.",
          "priority": 3
        }
      ]
    },
    "system_health_meaning": {
      "description": "VPS /health 및 /status 응답 해석",
      "priority": 2,
      "rules": [
        {
          "condition": "status_server.status == 'RUNNING' AND /health HTTP 200",
          "external_ref": {
            "id": "DIS-010",
            "schema_version": "2.6"
          },
          "interpretation": "HEALTHY",
          "output_label": "시스템 정상 가동 중",
          "priority": 1
        },
        {
          "condition": "status_server.status == 'RUNNING' AND /health HTTP != 200",
          "external_ref": {
            "id": "DIS-010",
            "schema_version": "2.6"
          },
          "interpretation": "DEGRADED",
          "output_label": "WARN — 서비스 등록됨 but 응답 이상. 비오님 고지.",
          "priority": 2
        },
        {
          "condition": "status_server.status != 'RUNNING'",
          "external_ref": {
            "id": "DIS-010",
            "schema_version": "2.6"
          },
          "interpretation": "DOWN",
          "output_label": "STOP — VPS 서비스 미가동. 비오님 확인 필요.",
          "priority": 3
        }
      ]
    },
    "task_priority": {
      "description": "pending_tasks 우선순위 해석",
      "priority": 2,
      "rules": [
        {
          "condition": "pending_tasks[0].status == 'BLOCKED'",
          "external_ref": {
            "id": "DIS-010",
            "schema_version": "2.6"
          },
          "interpretation": "BLOCKED",
          "output_label": "STOP — blocked_by 해소 전 착수 불가",
          "priority": 1
        },
        {
          "condition": "pending_tasks is empty or null",
          "external_ref": {
            "id": "DIS-008",
            "schema_version": "2.6"
          },
          "interpretation": "NO_TASK",
          "output_label": "N/A — IR-NULL-001 적용",
          "patch_ref": "IR-NULL-001",
          "priority": 2
        },
        {
          "condition": "pending_tasks[0].priority == 'HIGH'",
          "external_ref": {
            "id": "DIS-010",
            "schema_version": "2.6"
          },
          "interpretation": "HIGH_PRIORITY_ACTIVE",
          "output_label": "최우선 태스크 존재 — 즉시 착수 필요",
          "priority": 3
        },
        {
          "condition": "pending_tasks[0].priority == 'MEDIUM'",
          "external_ref": {
            "id": "DIS-010",
            "schema_version": "2.6"
          },
          "interpretation": "MEDIUM_PRIORITY_ACTIVE",
          "output_label": "중순위 태스크 대기 중",
          "priority": 4
        }
      ]
    }
  },
