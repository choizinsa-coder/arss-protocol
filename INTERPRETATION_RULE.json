    "fallback_policy": "fallback 금지 — 모든 미정의 상태는 STOP 처리.",
    "on_conflict": "STOP — priority 동점. 비오님 확인 요청 후 작업 중단.",
    "on_invalid_external_ref": "STOP — 참조 대상 미존재 또는 schema 불일치. 비오님 확인 요청 후 작업 중단.",
    "on_no_rule": "STOP — 매핑 불가 상태. 비오님 확인 요청 후 작업 중단.",
    "rule_evaluation_basis": "priority 단일 기준 — 낮은 수치 우선(1>2>3). priority 외 기준 적용 금지."
  },
  "patches": {
    "IR-NULL-001": {
      "action": "phase_status → IDLE로 해석. task_priority → N/A. execution_gate → OPEN(blocking 없음).",
      "condition": "pending_tasks 배열이 비어 있거나 null인 경우",
      "description": "pending_tasks empty 대응",
      "external_ref": {
        "id": "DIS-008",
        "schema_version": "2.6"
      },
      "note": "STOP 아님 — 정상 상태로 처리"
    }
